# %SYMTAB Section
# An enumeration of all symbols in the program.
# The beginning of the section is indicated by %SYMTAB.
# Each line describes a single symbol as follows:
#    <label> <value> [-]<load-adj> <class> <space> <psect> <file-name>
# The value and load-adj are both in unqualified hexadecimal.
# All other numeric values are in decimal.  The load-adj is the
# quantity one needs to add to the symbol value in order to obtain the load
# address of the symbol.  This value may be signed. If the symbol
# was defined in a psect then <psect> will be "-". File-name
# is the name of the object file in which the symbol was defined.
%SYMTAB
___latbits 2 0 ABS 0 - build\test_Hardware_UART.o
__Hspace_0 3F0 0 ABS 0 - -
__Hspace_1 7E 0 ABS 0 - -
__Hspace_2 54 0 ABS 0 - -
__Hspace_3 0 0 ABS 0 - -
__Heeprom_data 0 0 EEDATA 3 eeprom_data -
__L__absolute__ 0 0 ABS 0 __absolute__ -
__Hstrings 54 0 ABS 0 strings -
i1GPIO_GetPinValue@Port 72 0 COMMON 1 cstackCOMMON build\test_Hardware_UART.o
___sp 54 0 STACK 2 stack build\startup.o
_main 2E8 0 CODE 0 maintext build\test_Hardware_UART.o
btemp 7E 0 ABS 0 - build\test_Hardware_UART.o
___stack_hi 54 0 STACK 2 stack build\startup.o
___stack_lo 54 0 STACK 2 stack build\startup.o
i1GPIO_GetPinValue@Pin 70 0 COMMON 1 cstackCOMMON build\test_Hardware_UART.o
start 20 0 CODE 0 init build\startup.o
__pfunctab 3A 0 ENTRY 0 functab build\test_Hardware_UART.o
__size_of__i1fptable 0 0 ABS 0 - build\test_Hardware_UART.o
